{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".cache/tsbuildinfo.json",
        "dist/**"
      ],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": false
    },
    "start": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".cache/.eslintcache"
      ],
      "cache": true
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".cache/tsbuildinfo.json"
      ],
      "cache": true
    },
    "test": {
      "dependsOn": [
        "^test"
      ],
      "cache": true,
      "outputs": [
        "coverage/**"
      ]
    },
    "test:cov": {
      "dependsOn": [
        "^test:cov"
      ],
      "cache": true,
      "outputs": [
        "coverage/**"
      ]
    },
    "format": {
      "outputs": [
        ".cache/.prettiercache"
      ],
      "outputLogs": "new-only"
    },
    "clean": {
      "cache": false
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "studio": {
      "cache": false,
      "persistent": true
    }
  },
  "globalPassThroughEnv": [
    "NODE_ENV",
    "CI"
  ]
}